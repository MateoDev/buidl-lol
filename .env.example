# ============================================================================
# buidl.lol Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.

# Database (Neon/Supabase/Local Postgres)
# Example Neon: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/buidl_lol"

# Discord Bot
DISCORD_TOKEN="your_discord_bot_token"
DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_GUILD_ID="your_discord_guild_id"

# OpenClaw (if using managed runtime)
OPENCLAW_API_KEY="your_openclaw_api_key"

# Auth (SIWE)
NEXTAUTH_SECRET="generate_with_openssl_rand_base64_32"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Analytics
POSTHOG_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# Optional: Email (for notifications)
RESEND_API_KEY=""
